# Dependencies
node_modules/

# Build output
dist/
dist-ssr/
build/

# Environment variables — never commit these. This is the one that
# matters most right now: your VITE_GOOGLE_CLIENT_ID lives in .env, and
# while that specific value isn't secret, .env is exactly where you'd
# accidentally also commit something that IS secret later (API keys,
# tokens, ant others) if this weren't ignored from the start.
.env
.env.local
.env.*.local

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log

# Editor / IDE
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# OS files
.DS_Store
Thumbs.db

# Vite
*.local